{
  "name": "golf-3-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "start:backend": "npm run start --workspace=backend",
    "start:frontend": "npm run start --workspace=frontend",
    "start": "concurrently --raw \"npm run start --workspace=backend\" \"npm run start --workspace=frontend\"",
    "rebuild-native": "npm run rebuild-native --workspace=backend"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  },
  "overrides": {
    "ip-address": ">=10.2.0",
    "ws": "8.20.1",
    "protobufjs": "8.4.0",
    "brace-expansion": "5.0.6",
    "serve-static": "1.16.2",
    "cookie": "0.7.2",
    "send": "1.2.0",
    "mime": "1.6.0",
    "immutable": "5.1.5",
    "picomatch": ">=2.3.2",
    "path-to-regexp": ">=8.4.0",
    "lodash": "4.18.1",
    "follow-redirects": "1.16.0",
    "postcss": ">=8.5.10"
  },
  "dependencies": {
    "basic-ftp": "^5.3.1",
    "qs": "^6.15.2"
  }
}
